# SurplusAS API v2.0 — environment template.
# Copy to .env and fill in. Never commit .env (it's in .gitignore).

# --- Vertex AI / ADK ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=ps2o-surplusas-api
GOOGLE_CLOUD_LOCATION=us-central1

# --- Local auth ---
# Run once: gcloud auth application-default login
# ADC is read from %APPDATA%\gcloud\application_default_credentials.json (Windows)
# or ~/.config/gcloud/application_default_credentials.json (Mac/Linux).

# --- Model selection (per-service overrides) ---
LISTING_MODEL=gemini-2.5-flash
COMPLIANCE_MODEL=gemini-2.5-flash
PRICING_MODEL=gemini-2.5-flash

# --- Cloud SQL Postgres (Phase 3b) ---
# Connection-name format: PROJECT:REGION:INSTANCE
CLOUD_SQL_INSTANCE=ps2o-surplusas-api:us-central1:surplusas-db
DB_NAME=surplusas
DB_USER=surplusas_app
DB_PASSWORD=
# Set to "true" if connecting via private IP (Cloud Run + Serverless VPC Connector).
DB_PRIVATE_IP=false

# --- API auth ---
# Demo partner key, seeded into partner_keys table by shared/db_init.py.
SURPLUSAS_API_KEY=sk_demo_surplus_2026

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8080
DEBUG=false
